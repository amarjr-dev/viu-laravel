{
    "name": "viu/viu-laravel",
    "description": "Laravel SDK for Viu logging platform — Monolog Handler, Facade, HTTP/Kafka transport",
    "type": "library",
    "version": "0.1.0",
    "keywords": ["viu", "logging", "laravel", "monolog", "kafka", "observability", "loki"],
    "license": "MIT",
    "authors": [
        {
            "name": "amar.jr",
            "email": "amarjr.dev@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/log": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "monolog/monolog": "^3.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5|^11.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0"
    },
    "suggest": {
        "longlang/phpkafka": "Required for Kafka transport mode (composer require longlang/phpkafka)"
    },
    "autoload": {
        "psr-4": {
            "Viu\\ViuLaravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Viu\\ViuLaravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Viu\\ViuLaravel\\ViuServiceProvider"
            ],
            "aliases": {
                "Viu": "Viu\\ViuLaravel\\Facades\\Viu"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
